[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://content/bind/xtc_options.gd" id="1_xtc"]

[node name="XtcOptions" type="VBoxContainer"]
theme_override_constants/separation = 8
script = ExtResource("1_xtc")

[node name="Grid" type="GridContainer" parent="."]
layout_mode = 2
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 6
columns = 2

[node name="LblDither" type="Label" parent="Grid"]
layout_mode = 2
text = "Dither"

[node name="DitherOption" type="OptionButton" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3

[node name="LblDownscale" type="Label" parent="Grid"]
layout_mode = 2
text = "Downscale"

[node name="DownscaleOption" type="OptionButton" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3

[node name="LblLandscape" type="Label" parent="Grid"]
layout_mode = 2
text = "Landscape split"

[node name="LandscapeOption" type="OptionButton" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3

[node name="LblOverview" type="Label" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
text = "Overview da página"

[node name="OverviewOption" type="OptionButton" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3

[node name="LblGamma" type="Label" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
text = "Gamma (brilho)"

[node name="GammaSpin" type="SpinBox" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
min_value = 0.1
max_value = 3.0
step = 0.1
value = 1.0

[node name="LblContrast" type="Label" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
text = "Contraste (0-8)"

[node name="ContrastSpin" type="SpinBox" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
max_value = 8.0
value = 4.0

[node name="LblManhwaOv" type="Label" parent="Grid"]
layout_mode = 2
text = "Manhwa overlap %"

[node name="ManhwaOverlapSpin" type="SpinBox" parent="Grid"]
unique_name_in_owner = true
layout_mode = 2
max_value = 90.0
value = 40.0

[node name="Checks" type="HFlowContainer" parent="."]
layout_mode = 2
theme_override_constants/h_separation = 12

[node name="TwoBitCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "2-bit (.xtch)"

[node name="CompressCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "Compress (.xtcz)"

[node name="InvertCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "Inverter"

[node name="ManhwaCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "Manhwa (webtoon)"

[node name="KeepCoverCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
button_pressed = true
text = "Manter capa inteira"

[node name="SplitAllCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "Split all"

[node name="PadBlackCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
text = "Pad preto"

[node name="OverlapCheck" type="CheckBox" parent="Checks"]
unique_name_in_owner = true
layout_mode = 2
button_pressed = true
text = "Overlap 3x"
